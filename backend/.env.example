# ═══════════════════════════════════════════════════════════
# Lumora Backend — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Azure OpenAI (LLM) — recommended ─────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Azure OpenAI (Embeddings) ─────────────────────────────
AZURE_OPENAI_EMB_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_EMB_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_EMB_API_VERSION=2025-01-01-preview
AZURE_OPENAI_EMB_DEPLOYMENT=text-embedding-ada-002

# ── Force provider override ───────────────────────────────
# Set to "gemini" to always use Gemini even if Azure keys exist
# Options: azure | gemini | openai | anthropic | (blank = auto-detect)
FORCE_PROVIDER=

# ── Google Gemini (free tier) ─────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_GEMINI_MODEL=gemini-1.5-flash
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# ── Alternatively: standard OpenAI ───────────────────────
# OPENAI_API_KEY=sk-...
# DEFAULT_MODEL=gpt-4o-mini

# ── Alternatively: Anthropic ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_MODEL=claude-sonnet-4-6

# ── Knowledge Graph (optional — NetworkX used if blank) ───
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ── Storage paths ─────────────────────────────────────────
LANCEDB_PATH=./data/lancedb
FILESYSTEM_BASE_DIR=./data/uploads

# ── Server ────────────────────────────────────────────────
# For production: set to your Vercel frontend URL
ALLOWED_ORIGINS=*
MAX_UPLOAD_SIZE_MB=50
DEBUG=false
