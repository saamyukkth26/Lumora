# ═══════════════════════════════════════════════════════
# Lumora Frontend — Environment Variables
# Copy this file to .env.local
# ═══════════════════════════════════════════════════════

# Backend URL (leave empty to use Vite proxy in development)
# In production, set to your Render backend URL:
# VITE_API_URL=https://lumora-backend.onrender.com/api/v1
VITE_API_URL=
